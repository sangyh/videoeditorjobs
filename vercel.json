{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/video-editor-jobs-remote/",
      "destination": "/remote-video-editor-jobs/",
      "permanent": true
    },
    {
      "source": "/remote-editor-jobs/",
      "destination": "/remote-video-editor-jobs/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "index, follow"
        }
      ]
    }
  ]
}
